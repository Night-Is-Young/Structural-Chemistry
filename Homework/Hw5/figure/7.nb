   SuperscriptBox["10", 
    RowBox[{"-", "34"}]]}]}], "\[IndentingNewLine]", 
 RowBox[{"h", ":=", 
  RowBox[{"2", "Pi", " ", "hbar"}]}], "\[IndentingNewLine]", 
 RowBox[{"c", ":=", "299792458"}], "\[IndentingNewLine]", 
 RowBox[{"w", ":=", 
  RowBox[{
  "2", "Pi", " ", "c", " ", "*", "2989", "*", 
   "100"}]}], "\[IndentingNewLine]", 
 RowBox[{"De", ":=", 
  RowBox[{"h", "*", "c", "*", " ", "4.325", "*", 
   SuperscriptBox["10", "6"]}]}], "\[IndentingNewLine]", 
 RowBox[{"a", ":=", 
  SuperscriptBox[
   RowBox[{"(", 
    FractionBox[
     RowBox[{
      SuperscriptBox["w", "2"], "m"}], 
     RowBox[{"4", "Pi", " ", "hbar", " ", "c", " ", "4.325", "*", 
      SuperscriptBox["10", "6"]}]], ")"}], 
   RowBox[{"1", "/", "2"}]]}], "\[IndentingNewLine]", 
 RowBox[{"lambda", ":=", 
  FractionBox[
   RowBox[{"Sqrt", "[", 
    RowBox[{"2", "m", " ", "De"}], "]"}], 
   RowBox[{"a", " ", "hbar"}]]}], "\[IndentingNewLine]", 
 RowBox[{"Gamma", "[", 
  RowBox[{"2", "lambda"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"z", "[", "x_", "]"}], ":=", 
  RowBox[{"2", "lambda", " ", 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{"-", "a"}], " ", "x"}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"t", "[", "x_", "]"}], ":=", 
  FractionBox["x", 
   SuperscriptBox["10", "12"]]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"psi00", "[", "x_", "]"}], ":=", 
  RowBox[{
   RowBox[{
    FractionBox["1", "4"], 
    RowBox[{"Log", "[", 
     FractionBox[
      RowBox[{"m", " ", "w"}], 
      RowBox[{"Pi", " ", "hbar"}]], "]"}]}], "-", 
   FractionBox[
    RowBox[{"m", " ", "w", " ", 
     SuperscriptBox[
      RowBox[{"t", "[", "x", "]"}], "2"]}], 
