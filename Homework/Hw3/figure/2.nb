  RowBox[{
   FractionBox["1", 
    RowBox[{"Sqrt", "[", "Pi", "]"}]], 
   RowBox[{"Exp", "[", 
    RowBox[{"-", 
     RowBox[{"Sqrt", "[", 
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
