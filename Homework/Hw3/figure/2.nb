      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"z", "+", "1"}], ")"}], "2"], "+", 
       SuperscriptBox["r", "2"]}], "]"}]}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"p1", "[", "z_", "]"}], ":=", 
